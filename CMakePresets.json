{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "cpu-headless",
      "displayName": "CPU-only headless (core + accel + CLI + tests)",
      "inherits": "base",
      "cacheVariables": {
        "CYBER_WITH_QUADCOVER": "ON"
      }
    },
    {
      "name": "cpu-headless-debug",
      "displayName": "CPU-only headless, Debug with sanitizers",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer"
      }
    },
    {
      "name": "macos-metal",
      "displayName": "macOS with Metal backend and renderer",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "cacheVariables": {
        "CYBER_ENABLE_METAL": "ON",
        "CYBER_BUILD_RENDER": "ON"
      }
    },
    {
      "name": "linux-cuda",
      "displayName": "Linux with CUDA (tier-1) + OpenCL (tier-2) backends",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
      "cacheVariables": {
        "CYBER_ENABLE_CUDA": "ON",
        "CYBER_ENABLE_OPENCL": "ON"
      }
    },
    {
      "name": "windows-cuda",
      "displayName": "Windows with CUDA backend",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Windows" },
      "cacheVariables": {
        "CYBER_ENABLE_CUDA": "ON"
      }
    },
    {
      "name": "ios",
      "displayName": "iPadOS/iOS (Metal, no CLI/tests)",
      "inherits": "base",
      "condition": { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" },
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "iOS",
        "CYBER_ENABLE_METAL": "ON",
        "CYBER_BUILD_RENDER": "ON",
        "CYBER_BUILD_CLI": "OFF",
        "CYBER_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "android",
      "displayName": "Android (Vulkan render, OpenCL where present)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_SYSTEM_NAME": "Android",
        "CYBER_ENABLE_OPENCL": "ON",
        "CYBER_BUILD_RENDER": "ON",
        "CYBER_BUILD_CLI": "OFF",
        "CYBER_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    { "name": "cpu-headless", "configurePreset": "cpu-headless" },
    { "name": "cpu-headless-debug", "configurePreset": "cpu-headless-debug" },
    { "name": "macos-metal", "configurePreset": "macos-metal" },
    { "name": "linux-cuda", "configurePreset": "linux-cuda" }
  ],
  "testPresets": [
    {
      "name": "cpu-headless",
      "configurePreset": "cpu-headless",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "cpu-headless-debug",
      "configurePreset": "cpu-headless-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "linux-cuda",
      "configurePreset": "linux-cuda",
      "output": { "outputOnFailure": true }
    }
  ]
}
